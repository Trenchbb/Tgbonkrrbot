# Telegram Bot Configuration
BOT_TOKEN=your_bot_token_here

# Private channel/group ID where files are stored
# Get this by forwarding a message from the channel to @userinfobot
# Format: -100xxxxxxxxx (for supergroups/channels)
VAULT_CHANNEL_ID=-1001234567890

# Comma-separated list of admin user IDs (allowed to upload files)
# Get your ID from @userinfobot
ADMIN_IDS=123456789,987654321